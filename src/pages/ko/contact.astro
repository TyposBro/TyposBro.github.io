---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../config';

const locale = 'ko' as const;
---

<Base locale={locale} title="연락 — Azizbek Umidjonov">
  <article class="max-w-xl">
    <h1 class="text-3xl font-bold tracking-tight mb-6">연락</h1>
    <p class="text-[var(--color-muted)] mb-8 leading-relaxed">
      가장 빠른 연락 방법은 이메일입니다. 영업일 기준 하루 안에 답변 드립니다.
      채용 담당자 분들께 — 포지션과 연봉 레인지를 먼저 공유해 주시면
      서로 시간을 아낄 수 있습니다.
    </p>

    <div class="space-y-4">
      <div class="flex items-center justify-between border-b border-[var(--color-border)] pb-3">
        <span class="text-[var(--color-muted)] text-sm uppercase tracking-wider">Email</span>
        <a href={`mailto:${SITE.email}`} class="font-mono">{SITE.email}</a>
      </div>
      <div class="flex items-center justify-between border-b border-[var(--color-border)] pb-3">
        <span class="text-[var(--color-muted)] text-sm uppercase tracking-wider">GitHub</span>
        <a href={SITE.github}>@TyposBro</a>
      </div>
      <div class="flex items-center justify-between border-b border-[var(--color-border)] pb-3">
        <span class="text-[var(--color-muted)] text-sm uppercase tracking-wider">LinkedIn</span>
        <a href={SITE.linkedin}>linkedin.com/in/typosbro54</a>
      </div>
      <div class="flex items-center justify-between border-b border-[var(--color-border)] pb-3">
        <span class="text-[var(--color-muted)] text-sm uppercase tracking-wider">Twitter</span>
        <a href={SITE.twitter}>@typosbro</a>
      </div>
    </div>
  </article>
</Base>
