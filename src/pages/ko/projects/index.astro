---
import Base from '../../../layouts/Base.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/utils';
import { HIDDEN_PROJECT_SLUGS } from '../../../config';

const locale = 'ko' as const;

const all = await getCollection('projects', ({ data }) =>
  data.locale === locale && !data.hidden && !HIDDEN_PROJECT_SLUGS.includes(data.key as any)
);
const projects = all.sort((a, b) => a.data.order - b.data.order);
---

<Base locale={locale} title="프로젝트 — Azizbek Umidjonov">
  <h1 class="text-3xl font-bold tracking-tight mb-8">{t(locale, 'projects.all')}</h1>
  <div class="grid sm:grid-cols-2 gap-6">
    {projects.map((p) => <ProjectCard project={p} locale={locale} />)}
  </div>
</Base>
