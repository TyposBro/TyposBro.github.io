---
import Base from '../../../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('posts', ({ data }) =>
    data.locale === 'ru' && !data.draft
  );
  return all.map((post) => ({ params: { slug: post.data.key }, props: { post } }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Base locale="ru" title={`${post.data.title} — Azizbek Umidjonov`} description={post.data.excerpt}>
  <article class="max-w-2xl mx-auto">
    <header class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight mb-2">{post.data.title}</h1>
      <time class="text-sm font-mono text-[var(--color-muted)]" datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </header>
    <div class="prose prose-invert max-w-none prose-headings:font-semibold prose-p:text-[var(--color-fg)] prose-a:text-[var(--color-accent)]">
      <Content />
    </div>
  </article>
</Base>
