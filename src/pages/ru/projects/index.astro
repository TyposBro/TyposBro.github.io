---
import Base from '../../../layouts/Base.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/utils';
import { HIDDEN_PROJECT_SLUGS } from '../../../config';

const locale = 'ru' as const;

const all = await getCollection('projects', ({ data }) =>
  (data.locale === 'ru' || data.locale === 'en') &&
  !data.hidden &&
  !HIDDEN_PROJECT_SLUGS.includes(data.key as any)
);
const bySlug = new Map<string, typeof all[number]>();
for (const p of all) {
  const existing = bySlug.get(p.data.key);
  if (!existing || (existing.data.locale === 'en' && p.data.locale === 'ru')) {
    bySlug.set(p.data.key, p);
  }
}
const projects = Array.from(bySlug.values()).sort((a, b) => a.data.order - b.data.order);
---

<Base locale={locale} title="Проекты — Azizbek Umidjonov">
  <h1 class="text-3xl font-bold tracking-tight mb-8">{t(locale, 'projects.all')}</h1>
  <div class="grid sm:grid-cols-2 gap-6">
    {projects.map((p) => <ProjectCard project={p} locale={locale} />)}
  </div>
</Base>
